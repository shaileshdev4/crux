# Optional: enables Groq-powered extraction and insight narration.
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_EXTRACT_MODEL=llama-3.1-8b-instant

# Optional: auth + persistence. Without these, the app runs in anonymous sample mode.
# Set the same values in Vercel → Project → Settings → Environment Variables.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Production site URL — used for OAuth redirects and Open Graph (set in Vercel too)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
